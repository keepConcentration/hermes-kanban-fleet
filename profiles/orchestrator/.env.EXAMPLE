# Orchestrator Discord + gateway
# Copy to the installed profile .env and fill in real values.

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
DISCORD_ALLOW_BOTS=mentions
DISCORD_REPLY_TO_MODE=off
DISCORD_ALLOW_MENTION_REPLIED_USER=false

# Optional: allow bot messages only via @mention of this orchestrator bot
# DISCORD_REQUIRE_MENTION=true
