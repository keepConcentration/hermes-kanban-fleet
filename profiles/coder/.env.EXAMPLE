# Coder — Claude Code ACP + Discord (worker)
# Copy to the installed profile .env and fill in real values.
# Requires: npm i -g @agentclientprotocol/claude-agent-acp
# And a logged-in Claude Code CLI (`claude auth`).

DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
DISCORD_HOME_CHANNEL=
# CRITICAL: workers must ignore other bots (anti ack-loop)
DISCORD_ALLOW_BOTS=none
DISCORD_REPLY_TO_MODE=off
DISCORD_ALLOW_MENTION_REPLIED_USER=false

# Claude Agent ACP via Node
# Example (Windows):
# HERMES_COPILOT_ACP_COMMAND=C:/Program Files/nodejs/node.exe
# HERMES_COPILOT_ACP_ARGS=C:/Users/<you>/AppData/Roaming/npm/node_modules/@agentclientprotocol/claude-agent-acp/dist/index.js
HERMES_COPILOT_ACP_COMMAND=
HERMES_COPILOT_ACP_ARGS=
COPILOT_CLI_PATH=
HERMES_ACP_AUTO_APPROVE=1
