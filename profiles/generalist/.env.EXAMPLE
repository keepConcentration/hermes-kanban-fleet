# Generalist — Cursor ACP (worker)
# Copy to the installed profile .env and fill in real values.

# Cursor ACP (copilot-acp provider)
# Example (Windows):
# HERMES_COPILOT_ACP_COMMAND=C:/Users/<you>/AppData/Local/cursor-agent/versions/<ver>/node.exe
# HERMES_COPILOT_ACP_ARGS=C:/Users/<you>/AppData/Local/cursor-agent/versions/<ver>/index.js --mode ask acp
HERMES_COPILOT_ACP_COMMAND=
HERMES_COPILOT_ACP_ARGS=
COPILOT_CLI_PATH=
CURSOR_API_KEY=
HERMES_ACP_AUTH_METHOD=cursor_login
HERMES_ACP_AUTO_APPROVE=1
